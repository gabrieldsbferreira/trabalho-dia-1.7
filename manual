5. MainActivity.kt com RecyclerView básico
import android.os.Bundle
import androidx.appcompat.app.AppCompatActivity
import androidx.lifecycle.lifecycleScope
import androidx.room.Room
import kotlinx.coroutines.launch

class MainActivity : AppCompatActivity() {
    
    private lateinit var db: AppDatabase
    
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)
        
        // Inicia o banco
        db = Room.databaseBuilder(
            applicationContext,
            AppDatabase::class.java, "tarefas-db"
        ).build()
        
        // Teste: insere dados iniciais
        lifecycleScope.launch {
            val dao = db.tarefaDao()
            
            val usuario = Usuario(nome = "Aluno 1", email = "aluno1@email.com")
            dao.inserirUsuario(usuario)
            
            val categoria = Categoria(nome = "Estudos", cor = "#2196F3")
            dao.inserirCategoria(categoria)
            
            val tarefa = Tarefa(
                titulo = "Entregar trabalho de Kotlin",
                descricao = "Prazo 01/06",
                usuarioId = 1,
                categoriaId = 1
            )
            dao.inserirTarefa(tarefa)
        }
    }
}
